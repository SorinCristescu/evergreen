# Copy this file to `.env` and fill in your own values (do NOT commit `.env`).

# Convex deployment URL.
# Run `npx convex dev` once — it writes CONVEX_URL into .env.local. Copy that value here.
EXPO_PUBLIC_CONVEX_URL=

# Clerk publishable key (Clerk dashboard → API Keys → Publishable key).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=


